generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

enum PortfolioStatus {
  DRAFT
  PUBLISHED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model User {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId

  name            String
  email           String       @unique
  password        String?

  emailVerified   DateTime?

  phone           String?
  image           String?

  role            UserRole     @default(USER)
  status          UserStatus   @default(PENDING)

  isBlocked       Boolean      @default(false)

  portfolio       Portfolio?

  notifications   Notification[]
  accounts        Account[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Portfolio {
  id                    String            @id @default(auto()) @map("_id") @db.ObjectId

  userId                String            @unique @db.ObjectId
  user                  User              @relation(fields: [userId], references: [id])

  username              String            @unique

  title                 String?
  tagline               String?
  bio                   String?

  profileImage          String?
  coverImage            String?

  status                PortfolioStatus   @default(DRAFT)

  isPublic              Boolean           @default(false)

  allowContactForm      Boolean           @default(true)
  allowResumeDownload   Boolean           @default(true)

  totalViews            Int               @default(0)
  uniqueVisitors        Int               @default(0)

  seoTitle              String?
  seoDescription        String?
  seoKeywords           String?
  seoImage              String?

  activeThemeId         String?           @db.ObjectId

  resume                Resume?

  projects              Project[]
  educations            Education[]
  experiences           Experience[]
  skills                Skill[]
  achievements          Achievement[]

  socialLinks           SocialLink[]
  codingProfiles        CodingProfile[]

  customSections        CustomSection[]
  themes                Theme[]

  analytics             Analytics?
  views                 PortfolioView[]

  contactMessages       ContactMessage[]

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  slug                  String?           @unique
}

model Resume {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId   String     @unique @db.ObjectId
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id])

  fileName      String
  fileUrl       String

  fileSize      Int?

  uploadedAt    DateTime   @default(now())

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}
model Project {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId   String     @db.ObjectId
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id])

  title         String
  description   String

  techStack     String[]

  githubUrl     String?
  liveUrl       String?

  imageUrls     String[]
  videoUrl      String?

  featured      Boolean    @default(false)

  displayOrder  Int        @default(0)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Education {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId   String     @db.ObjectId
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id])

  institution   String
  degree        String

  fieldOfStudy  String?

  startDate     DateTime?
  endDate       DateTime?

  grade         String?

  description   String?

  createdAt     DateTime   @default(now())
}

model Experience {
  id                String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId       String     @db.ObjectId
  portfolio         Portfolio  @relation(fields: [portfolioId], references: [id])

  company           String
  position          String

  location          String?

  startDate         DateTime?
  endDate           DateTime?

  currentlyWorking  Boolean    @default(false)

  description       String?

  createdAt         DateTime   @default(now())
}

model Skill {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId   String     @db.ObjectId
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id])

  name          String

  category      String?
  level         Int?

  displayOrder  Int        @default(0)

  createdAt     DateTime   @default(now())
}

model Achievement {
  id                String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId       String     @db.ObjectId
  portfolio         Portfolio  @relation(fields: [portfolioId], references: [id])

  title             String
  description       String?

  issuer            String?

  achievementDate   DateTime?

  url               String?

  createdAt         DateTime   @default(now())
}

model SocialLink {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId   String     @db.ObjectId
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id])

  platform      String
  label         String?
  url           String

  createdAt     DateTime   @default(now())
}

model CodingProfile {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId   String     @db.ObjectId
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id])

  platform      String
  username      String
  profileUrl    String

  rating        Int?
  rank          String?

  createdAt     DateTime   @default(now())
}
model CustomSection {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId   String     @db.ObjectId
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id])

  title         String
  content       String

  displayOrder  Int        @default(0)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Theme {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId     String     @db.ObjectId
  portfolio       Portfolio  @relation(fields: [portfolioId], references: [id])

  name            String

  primaryColor    String?
  secondaryColor  String?

  font            String?
  layout          String?

  darkMode        Boolean    @default(false)

  isActive        Boolean    @default(false)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Analytics {
  id                String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId       String     @unique @db.ObjectId
  portfolio         Portfolio  @relation(fields: [portfolioId], references: [id])

  totalViews        Int        @default(0)
  uniqueVisitors    Int        @default(0)

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model PortfolioView {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId     String     @db.ObjectId
  portfolio       Portfolio  @relation(fields: [portfolioId], references: [id])

  ipHash          String?
  country         String?
  city            String?

  device          String?
  browser         String?

  referrer        String?

  viewedAt        DateTime   @default(now())
  expiresAt       DateTime?

  @@index([viewedAt])
}

model Notification {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId

  userId        String            @db.ObjectId
  user          User              @relation(fields: [userId], references: [id])

  title         String
  message       String

  type          NotificationType  @default(INFO)

  isRead        Boolean           @default(false)

  createdAt     DateTime          @default(now())
}

model ContactMessage {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId

  portfolioId   String     @db.ObjectId
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id])

  name          String
  email         String

  subject       String?
  message       String

  isRead        Boolean    @default(false)
  replied       Boolean    @default(false)

  createdAt     DateTime   @default(now())
}model Account {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId

  userId            String   @db.ObjectId
  user              User     @relation(fields: [userId], references: [id])

  provider          String
  providerAccountId String

  access_token      String?
  refresh_token     String?
  expires_at        Int?

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
